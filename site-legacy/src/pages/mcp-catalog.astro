---
import BaseLayout from '@layouts/BaseLayout.astro';
const githubHref = 'https://github.com/paulasilvatech/agentic-sdlc-personas/blob/main/docs/registry/mcp-catalog.md';

const mcps = [
  { name: 'GitHub MCP Server',        status: 'Official',   href: 'https://github.com/github/github-mcp-server',                                                                            accent: 'ink'    },
  { name: 'Azure DevOps MCP Server',  status: 'Official',   href: 'https://github.com/microsoft/azure-devops-mcp',                                                                          accent: 'blue'   },
  { name: 'Microsoft Learn Docs MCP', status: 'Official',   href: 'https://github.com/microsoftdocs/mcp',                                                                                   accent: 'blue'   },
  { name: 'Azure MCP Server',         status: 'Official',   href: 'https://github.com/microsoft/mcp/blob/main/servers/Azure.Mcp.Server/README.md',                                          accent: 'blue'   },
  { name: 'Atlassian Rovo MCP',       status: 'Official',   href: 'https://github.com/atlassian/atlassian-mcp-server',                                                                      accent: 'ink'    },
  { name: 'Linear MCP Server',        status: 'Official',   href: 'https://linear.app/docs/mcp',                                                                                             accent: 'ink'    },
  { name: 'Notion MCP Server',        status: 'Official',   href: 'https://github.com/makenotion/notion-mcp-server',                                                                        accent: 'ink'    },
  { name: 'Figma Dev Mode MCP',       status: 'Official',   href: 'https://developers.figma.com/docs/figma-mcp-server/',                                                                     accent: 'red'    },
  { name: 'Sentry MCP Server',        status: 'Official',   href: 'https://github.com/getsentry/sentry-mcp',                                                                                accent: 'red'    },
  { name: 'Slack MCP Server',         status: 'Official',   href: 'https://slack.dev/secure-data-connectivity-for-the-modern-ai-era/',                                                       accent: 'yellow' },
  { name: 'PostgreSQL MCP',           status: 'Reference',  href: 'https://www.npmjs.com/package/@modelcontextprotocol/server-postgres',                                                     accent: 'green'  },
  { name: 'Grafana MCP Server',       status: 'Official',   href: 'https://github.com/grafana/mcp-grafana',                                                                                 accent: 'yellow' },
  { name: 'Terraform MCP Server',     status: 'Official',   href: 'https://github.com/hashicorp/terraform-mcp-server',                                                                      accent: 'ink'    },
  { name: 'Snyk MCP Server',          status: 'Official',   href: 'https://docs.snyk.io/scan-with-snyk/snyk-mcp',                                                                            accent: 'red'    },
  { name: 'Playwright MCP',           status: 'Official',   href: 'https://github.com/microsoft/playwright-mcp',                                                                            accent: 'green'  },
  { name: 'Filesystem MCP',           status: 'Reference',  href: 'https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem',                                                accent: 'ink'    }
];
---
<BaseLayout locale="en" title="MCP Catalog · Agentic SDLC Personas" description="Sixteen validated Model Context Protocol servers with official links.">
  <section class="section">
    <div class="container">
      <div class="section__header">
        <div class="section__label">Catalog</div>
        <h1 class="section__title">Validated MCP servers, no fiction</h1>
        <p class="section__lead">Every MCP recommended by this framework has a live repository or hosted endpoint, a status classification, and an official link. Anyone can verify each entry in minutes.</p>
      </div>

      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:32px;">
        <a class="btn btn--primary" href={githubHref}>Full catalog on GitHub <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;">
        {mcps.map(m => (
          <a class="card" href={m.href} data-accent={m.accent}>
            <div class="card__accent"></div>
            <div class="card__body" style="padding:20px 22px;">
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;color:var(--ink-3);text-transform:uppercase;">{m.status}</span>
                <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;stroke-width:2;fill:none;opacity:0.5;"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
              <div style="font-size:17px;font-weight:500;margin-top:8px;">{m.name}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
