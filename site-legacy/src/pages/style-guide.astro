---
import BaseLayout from '@layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const githubHref = 'https://github.com/paulasilvatech/agentic-sdlc-personas/blob/main/docs/STYLE_GUIDE.md';
---
<BaseLayout locale="en" title="Style Guide · Agentic SDLC Personas" description="Editorial and formatting rules for every markdown document in this repository.">
  <section class="section">
    <div class="container">
      <div class="section__header">
        <div class="section__label">Editorial</div>
        <h1 class="section__title">Style Guide</h1>
        <p class="section__lead">Every markdown document in this repository follows a single editorial contract: frontmatter, numbered table of contents, previous and next navigation, icons only in H1, paulasilvatech Design System palette, and only validated MCPs.</p>
      </div>

      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:32px;">
        <a class="btn btn--primary" href={githubHref}>Read the full guide on GitHub <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
        <a class="btn btn--ghost" href={`${base}/mcp-catalog`}>MCP catalog</a>
        <a class="btn btn--ghost" href={`${base}/personas`}>24 personas</a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;">
        <div class="card" data-accent="red"><div class="card__accent"></div><div class="card__body"><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3);">Intent</div><div style="font-size:16px;margin-top:6px;font-weight:500;">Frontmatter required</div><p style="margin:8px 0 0;font-size:14px;color:var(--ink-2);">title, description, author, date, version, status, locale, tags on every document.</p></div></div>
        <div class="card" data-accent="yellow"><div class="card__accent"></div><div class="card__body"><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3);">Context</div><div style="font-size:16px;margin-top:6px;font-weight:500;">Sumário + navigation</div><p style="margin:8px 0 0;font-size:14px;color:var(--ink-2);">Numbered table of contents, previous and next links top and bottom, footer attribution.</p></div></div>
        <div class="card" data-accent="green"><div class="card__accent"></div><div class="card__body"><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3);">Platform</div><div style="font-size:16px;margin-top:6px;font-weight:500;">14 canonical sections</div><p style="margin:8px 0 0;font-size:14px;color:var(--ink-2);">Every persona document follows the same fourteen numbered sections, from executive summary to references.</p></div></div>
        <div class="card" data-accent="blue"><div class="card__accent"></div><div class="card__body"><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3);">Infra</div><div style="font-size:16px;margin-top:6px;font-weight:500;">Validated MCPs only</div><p style="margin:8px 0 0;font-size:14px;color:var(--ink-2);">No invented MCPs. Every recommended server appears in the catalog with an official link.</p></div></div>
      </div>
    </div>
  </section>
</BaseLayout>
