---
import '../styles/global.css';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import SearchOverlay from '../components/layout/SearchOverlay.astro';
import type { Locale } from '../lib/i18n';
import { getStrings, getLocaleFromUrl } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  ogImage?: string;
}

const locale: Locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url.pathname);
const t = getStrings(locale);
const { title, description, ogImage } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle = title === t.site.title ? title : `${title} · ${t.site.title}`;
const metaDesc = description ?? t.site.tagline + '.';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDesc} />
    <meta name="author" content="Paula Silva, AI-Native Software Engineer" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="canonical" href={canonical} />

    <link rel="stylesheet" href={`${base}/tokens.css`} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">

    <link rel="icon" href="data:," />

    {/* Set theme on FOUC prevention before paint */}
    <script is:inline>
      (function(){
        try {
          var k='ps-theme';
          var t=localStorage.getItem(k);
          var d=window.matchMedia&&matchMedia('(prefers-color-scheme: dark)').matches;
          if(t==='dark'||(!t&&d))document.documentElement.setAttribute('data-theme','dark');
        } catch(e){}
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t.nav.skipToContent}</a>
    <SiteHeader locale={locale} currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter locale={locale} />
    <SearchOverlay locale={locale} />

    <style is:global>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 10px;
        padding: 8px 14px;
        background: var(--ps-color-ms-blue-500);
        color: white;
        text-decoration: none;
        font-family: var(--ps-font-mono);
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        border-radius: 4px;
        z-index: 200;
      }
      .skip-link:focus { top: 10px; }
    </style>
  </body>
</html>
