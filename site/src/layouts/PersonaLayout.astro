---
import BaseLayout from './BaseLayout.astro';
import SiteSidebar from '../components/layout/SiteSidebar.astro';
import TableOfContents from '../components/layout/TableOfContents.astro';
import PersonaNav from '../components/layout/PersonaNav.astro';
import type { Locale } from '../lib/i18n';
import { getPersonaNeighbors, getStrings } from '../lib/i18n';

interface Frontmatter {
  id: string;
  slug: string;
  number: number;
  cluster: string;
  accent: 'ink' | 'blue' | 'green' | 'yellow' | 'red';
  phase: string;
  title: string;
  oneLiner?: string;
  updated?: string;
}

interface Props {
  frontmatter: Frontmatter;
  slug: string;
  locale: Locale;
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { frontmatter: fm, slug, locale, headings } = Astro.props;
const { prev, next } = getPersonaNeighbors(slug);
const t = getStrings(locale);

const ACCENT: Record<string, string> = {
  blue:   'var(--ps-color-ms-blue-500)',
  green:  'var(--ps-color-ms-green-500)',
  yellow: 'var(--ps-color-ms-yellow-500)',
  red:    'var(--ps-color-ms-red-500)',
  ink:    'var(--ps-color-ink)',
};
const accent = ACCENT[fm.accent];
const num = String(fm.number).padStart(2, '0');
const base = import.meta.env.BASE_URL;
const iconPath = `${base}/icons/personas/${fm.id}.svg`.replace(/\/+/g, '/');
---

<BaseLayout title={fm.title} description={fm.oneLiner} locale={locale}>
  <div class="chapter-shell" id="top">
    <SiteSidebar locale={locale} currentSlug={slug} />

    <article class="chapter-main" data-pagefind-body>
      <header class="chapter-header">
        <div class="chapter-header__eyebrow-row">
          <span class="chapter-header__chip" style={`background:${accent}`}>{num}</span>
          <span class="chapter-header__eyebrow">{fm.cluster} · {fm.phase}</span>
        </div>
        <div class="chapter-header__title-row">
          <img src={iconPath} alt="" width="56" height="56" class="persona-icon" />
          <h1 class="chapter-header__title">{fm.title}</h1>
        </div>
        {fm.oneLiner && <p class="chapter-header__subtitle">{fm.oneLiner}</p>}
        <div class="chapter-header__meta">
          {fm.updated && <span>{t.common.updated}: {fm.updated}</span>}
          {headings.length > 0 && <span>{headings.filter(h => h.depth === 2).length} {t.common.sections}</span>}
        </div>
      </header>
      <hr class="chapter-divider" />

      <div class="prose">
        <slot />
      </div>

      <PersonaNav locale={locale} prev={prev} next={next} />
    </article>

    <TableOfContents headings={headings} locale={locale} />
  </div>
</BaseLayout>

<style>
  .chapter-shell { display: flex; max-width: 1600px; margin: 0 auto; gap: 0; }
  .chapter-main { flex: 1; min-width: 0; padding: 48px 56px 40px; max-width: 820px; margin: 0 auto; }
  .chapter-header__eyebrow-row { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; }
  .chapter-header__chip {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 40px; height: 40px; padding: 0 10px;
    font-family: var(--ps-font-mono); font-size: 13px; font-weight: 500; letter-spacing: 0.04em;
    color: white; border-radius: 6px;
  }
  .chapter-header__eyebrow {
    font-family: var(--ps-font-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--ps-color-ink-3);
  }
  .chapter-header__title-row { display: flex; align-items: center; gap: 20px; margin-bottom: 16px; }
  .persona-icon { flex-shrink: 0; border-radius: 8px; }
  .chapter-header__title {
    font-size: clamp(32px, 4vw, 48px); font-weight: 500; line-height: 1.05;
    letter-spacing: -0.025em; margin: 0; text-wrap: balance;
  }
  .chapter-header__subtitle {
    font-size: 19px; color: var(--ps-color-ink-2); line-height: 1.5;
    max-width: 60ch; margin: 0 0 24px; text-wrap: pretty;
  }
  .chapter-header__meta {
    display: flex; gap: 18px;
    font-family: var(--ps-font-mono); font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ps-color-ink-3);
    margin-top: 18px;
  }
  .chapter-divider { margin: 32px 0 40px; border: none; border-top: 1px solid var(--ps-color-rule); }
  @media (max-width: 1100px) { .chapter-main { padding: 40px 32px; max-width: none; } }
  @media (max-width: 860px) {
    .chapter-shell { flex-direction: column; }
    .chapter-main { padding: 32px 24px; }
  }
</style>
