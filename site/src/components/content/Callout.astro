---
interface Props {
  kind?: 'insight' | 'warning' | 'stat' | 'note' | 'quote';
  title?: string;
  source?: string;
}
const { kind = 'note', title, source } = Astro.props;

const LABELS: Record<string, string> = {
  insight: 'Insight',
  warning: 'Watch out',
  stat:    'By the numbers',
  note:    'Note',
  quote:   'Quote',
};
---

<aside class={`callout callout--${kind}`}>
  <span class="callout__kind">{LABELS[kind]}</span>
  {title && <div class="callout__title">{title}</div>}
  <div class="callout__body"><slot /></div>
  {source && <span class="callout__source">{source}</span>}
</aside>

<style>
  .callout {
    margin: 24px 0;
    padding: 20px 24px;
    border: 1px solid var(--ps-color-rule);
    border-left: 4px solid;
    border-radius: 0 8px 8px 0;
    font-size: 15px;
    line-height: 1.6;
  }
  .callout__kind {
    display: block;
    font-family: var(--ps-font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .callout__title {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 10px;
    line-height: 1.3;
    text-wrap: balance;
  }
  .callout__body :global(> *) { margin: 0.4em 0; }
  .callout__body :global(> *:first-child) { margin-top: 0; }
  .callout__body :global(> *:last-child)  { margin-bottom: 0; }
  .callout__source {
    display: block;
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid rgba(0,0,0,0.06);
    font-family: var(--ps-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ps-color-ink-3);
  }
  .callout--stat    { background: var(--ps-color-ms-green-50);  border-left-color: var(--ps-color-ms-green-500); }
  .callout--stat    .callout__kind { color: var(--ps-color-ms-green-700); }
  .callout--insight { background: var(--ps-color-ms-blue-50);   border-left-color: var(--ps-color-ms-blue-500); }
  .callout--insight .callout__kind { color: var(--ps-color-ms-blue-700); }
  .callout--warning { background: var(--ps-color-ms-red-50);    border-left-color: var(--ps-color-ms-red-500); }
  .callout--warning .callout__kind { color: var(--ps-color-ms-red-700); }
  .callout--quote   { background: var(--ps-color-ms-yellow-50); border-left-color: var(--ps-color-ms-yellow-500); }
  .callout--quote   .callout__kind { color: var(--ps-color-ms-yellow-700); }
  .callout--quote   .callout__body { font-style: italic; font-size: 17px; }
  .callout--note    { background: var(--ps-color-bg-alt);       border-left-color: var(--ps-color-ink-3); }
  .callout--note    .callout__kind { color: var(--ps-color-ink-3); }
</style>
