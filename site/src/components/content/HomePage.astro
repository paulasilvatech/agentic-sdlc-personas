---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Locale } from '../../lib/i18n';
import { getStrings, personaUrl, localePath, PERSONA_META } from '../../lib/i18n';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getStrings(locale);

const allPersonas = await getCollection('personas', ({ id }) => id.startsWith(`${locale}/`));
const personaData = new Map<string, { title: string; oneLiner?: string }>();
for (const p of allPersonas) {
  const fname = p.id.split('/').pop() || '';
  const slug = fname.replace(/^\d+-/, '');
  personaData.set(slug, { title: p.data.title, oneLiner: p.data.oneLiner });
}

const base = import.meta.env.BASE_URL;

const ACCENT: Record<string, { bg: string; border: string; ink: string; solid: string }> = {
  blue:   { bg: 'var(--ps-color-ms-blue-50)',   border: 'var(--ps-color-ms-blue-500)',   ink: 'var(--ps-color-ms-blue-700)',   solid: 'var(--ps-color-ms-blue-500)' },
  green:  { bg: 'var(--ps-color-ms-green-50)',  border: 'var(--ps-color-ms-green-500)',  ink: 'var(--ps-color-ms-green-700)',  solid: 'var(--ps-color-ms-green-500)' },
  yellow: { bg: 'var(--ps-color-ms-yellow-50)', border: 'var(--ps-color-ms-yellow-500)', ink: 'var(--ps-color-ms-yellow-700)', solid: 'var(--ps-color-ms-yellow-500)' },
  red:    { bg: 'var(--ps-color-ms-red-50)',    border: 'var(--ps-color-ms-red-500)',    ink: 'var(--ps-color-ms-red-700)',    solid: 'var(--ps-color-ms-red-500)' },
  ink:    { bg: 'var(--ps-color-bg-alt)',       border: 'var(--ps-color-rule-2)',        ink: 'var(--ps-color-ink)',           solid: 'var(--ps-color-ink)' },
};

const CLUSTER_ORDER = ['product', 'architect', 'enablement', 'ops', 'platform', 'quality', 'data', 'security', 'build'] as const;
const CLUSTER_LABELS: Record<string, { title: string; blurb: string }> = {
  product:    { title: 'Product',    blurb: 'Spec, KPIs, UX and requirements.' },
  architect:  { title: 'Architect',  blurb: 'Constitution, CODEMAP, API contracts.' },
  enablement: { title: 'Enablement', blurb: 'Teams, delivery and knowledge flow.' },
  ops:        { title: 'Ops',        blurb: 'Pipelines, reliability, releases.' },
  platform:   { title: 'Platform',   blurb: 'Golden paths and internal dev platform.' },
  quality:    { title: 'Quality',    blurb: 'Test strategy and acceptance.' },
  data:       { title: 'Data',       blurb: 'Pipelines, ML, data quality.' },
  security:   { title: 'Security',   blurb: 'InfoSec, compliance, audit.' },
  build:      { title: 'Build',      blurb: 'The developer in the agent loop.' },
};

const clusters = CLUSTER_ORDER.map(cl => ({
  id: cl,
  ...CLUSTER_LABELS[cl],
  personas: PERSONA_META.filter(p => p.cluster === cl),
}));
---

<BaseLayout title={t.site.title} description={t.site.tagline + '.'} locale={locale}>
  <section class="home-hero">
    <div class="home-hero__inner">
      <div class="home-hero__col">
        <div class="home-hero__eyebrow">{t.home.heroEyebrow}</div>
        <h1 class="home-hero__title">
          {t.home.heroTitle}{' '}
          <span class="home-hero__accent">{t.home.heroTitleAccent}</span>{' '}
          {t.home.heroTitleRest}
        </h1>
        <p class="home-hero__sub">{t.home.heroSubtitle}</p>
        <div class="home-hero__ctas">
          <a href={personaUrl(locale, 'product-owner')} class="home-hero__cta home-hero__cta--primary">
            {t.home.heroCtaStart} <span aria-hidden="true">→</span>
          </a>
          <a href="https://github.com/paulasilvatech/agentic-sdlc-personas" class="home-hero__cta home-hero__cta--secondary">
            {t.home.heroCtaDeck}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-why">
    <div class="home-section__inner">
      <h2 class="home-section__title">{t.home.whyTitle}</h2>
      <p class="home-section__body">{t.home.whyBody}</p>
    </div>
  </section>

  <section class="home-section home-clusters">
    <div class="home-section__inner">
      <h2 class="home-section__title">{t.home.chaptersTitle}</h2>
      <p class="home-section__body">{t.home.chaptersSubtitle}</p>

      <div class="cluster-grid">
        {clusters.map(cluster => {
          const first = cluster.personas[0];
          const accent = first ? ACCENT[first.accent] : ACCENT.ink;
          return (
            <article class="cluster-card" style={`--cluster-ink:${accent.ink};--cluster-solid:${accent.solid};--cluster-bg:${accent.bg};--cluster-border:${accent.border}`}>
              <header class="cluster-card__header">
                <h3 class="cluster-card__title">{cluster.title}</h3>
                <p class="cluster-card__blurb">{cluster.blurb}</p>
              </header>
              <ul class="cluster-card__list">
                {cluster.personas.map(p => {
                  const num = String(p.number).padStart(2, '0');
                  const meta = personaData.get(p.slug);
                  return (
                    <li>
                      <a href={personaUrl(locale, p.slug)} class="cluster-card__link">
                        <span class="cluster-card__num">{num}</span>
                        <span class="cluster-card__persona">{meta?.title ?? p.slug}</span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="home-section home-kits">
    <div class="home-section__inner home-section__inner--two">
      <div>
        <h2 class="home-section__title">{t.home.integrationTitle}</h2>
        <p class="home-section__body">{t.home.integrationBody}</p>
      </div>
      <div>
        <h2 class="home-section__title">{t.home.audienceTitle}</h2>
        <ul class="home-audience">
          {t.home.audienceList.map((it: string) => <li>{it}</li>)}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero { padding: 80px 28px 56px; border-bottom: 1px solid var(--ps-color-rule); }
  .home-hero__inner { max-width: 1200px; margin: 0 auto; }
  .home-hero__col { max-width: 840px; }
  .home-hero__eyebrow {
    font-family: var(--ps-font-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--ps-color-ink-3);
    margin-bottom: 18px;
  }
  .home-hero__title {
    font-size: clamp(40px, 5.5vw, 72px); font-weight: 500; line-height: 1.02;
    letter-spacing: -0.03em; margin: 0 0 22px; text-wrap: balance;
  }
  .home-hero__accent { color: var(--ps-color-ms-red-500); }
  .home-hero__sub {
    font-size: 20px; color: var(--ps-color-ink-2); line-height: 1.5;
    max-width: 62ch; margin: 0 0 32px; text-wrap: pretty;
  }
  .home-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .home-hero__cta {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 20px; border-radius: 6px; font-size: 14px; font-weight: 500;
    text-decoration: none; transition: border-color 0.12s ease, background 0.12s ease;
  }
  .home-hero__cta--primary { background: var(--ps-color-ink); color: var(--ps-color-paper); border: 1px solid var(--ps-color-ink); }
  .home-hero__cta--primary:hover { background: var(--ps-color-ms-blue-700); border-color: var(--ps-color-ms-blue-700); }
  .home-hero__cta--secondary { background: var(--ps-color-paper); color: var(--ps-color-ink); border: 1px solid var(--ps-color-rule-2); }
  .home-hero__cta--secondary:hover { border-color: var(--ps-color-ink); }

  .home-section { padding: 64px 28px; border-bottom: 1px solid var(--ps-color-rule); }
  .home-section__inner { max-width: 1200px; margin: 0 auto; }
  .home-section__inner--two {
    display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
  }
  @media (max-width: 760px) { .home-section__inner--two { grid-template-columns: 1fr; } }
  .home-section__title {
    font-size: 28px; font-weight: 500; letter-spacing: -0.015em;
    margin: 0 0 12px; line-height: 1.2;
  }
  .home-section__body {
    font-size: 17px; color: var(--ps-color-ink-2); line-height: 1.55;
    max-width: 68ch; margin: 0 0 32px;
  }
  .home-audience {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 10px;
  }
  .home-audience li {
    padding-left: 22px; position: relative;
    font-size: 15px; color: var(--ps-color-ink-2); line-height: 1.5;
  }
  .home-audience li::before {
    content: "→"; position: absolute; left: 0;
    color: var(--ps-color-ms-blue-500); font-family: var(--ps-font-mono);
  }

  .cluster-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
  .cluster-card {
    background: var(--ps-color-paper);
    border: 1px solid var(--ps-color-rule);
    border-radius: 10px;
    padding: 20px 22px;
    border-top: 3px solid var(--cluster-solid);
    display: flex; flex-direction: column; gap: 14px;
  }
  .cluster-card__title {
    font-size: 17px; font-weight: 500; margin: 0 0 4px;
    color: var(--cluster-ink);
  }
  .cluster-card__blurb {
    font-size: 13px; color: var(--ps-color-ink-3); margin: 0; line-height: 1.4;
  }
  .cluster-card__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 2px; }
  .cluster-card__link {
    display: grid; grid-template-columns: 32px 1fr;
    gap: 10px; align-items: center;
    padding: 6px 8px; border-radius: 5px;
    color: var(--ps-color-ink); text-decoration: none;
    font-size: 13.5px; line-height: 1.3;
    transition: background 0.12s ease;
  }
  .cluster-card__link:hover { background: var(--cluster-bg); }
  .cluster-card__num {
    font-family: var(--ps-font-mono); font-size: 10.5px;
    color: var(--ps-color-ink-3); letter-spacing: 0.04em;
  }
  .cluster-card__persona { text-wrap: balance; }
</style>
