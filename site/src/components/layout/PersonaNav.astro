---
import type { Locale, PersonaMeta } from '../../lib/i18n';
import { getStrings, personaUrl } from '../../lib/i18n';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
  prev?: PersonaMeta;
  next?: PersonaMeta;
}
const { locale, prev, next } = Astro.props;
const t = getStrings(locale);

const slugsOfInterest = [prev?.slug, next?.slug].filter(Boolean) as string[];
const personas = slugsOfInterest.length
  ? await getCollection('personas', ({ id }) => {
      if (!id.startsWith(`${locale}/`)) return false;
      const fname = id.split('/').pop() || '';
      const slug = fname.replace(/^\d+-/, '');
      return slugsOfInterest.includes(slug);
    })
  : [];

const titleMap = new Map<string, string>();
for (const p of personas) {
  const fname = p.id.split('/').pop() || '';
  const slug = fname.replace(/^\d+-/, '');
  titleMap.set(slug, p.data.title);
}

const prevTitle = prev ? titleMap.get(prev.slug) ?? prev.slug : '';
const nextTitle = next ? titleMap.get(next.slug) ?? next.slug : '';
---

<nav class="chapter-nav" aria-label="Persona navigation">
  {prev ? (
    <a href={personaUrl(locale, prev.slug)} class="chapter-nav__link chapter-nav__link--prev">
      <div class="chapter-nav__dir"><span aria-hidden="true">←</span> {t.nav.previousChapter}</div>
      <div class="chapter-nav__title">{prevTitle}</div>
    </a>
  ) : <div />}

  {next ? (
    <a href={personaUrl(locale, next.slug)} class="chapter-nav__link chapter-nav__link--next">
      <div class="chapter-nav__dir">{t.nav.nextChapter} <span aria-hidden="true">→</span></div>
      <div class="chapter-nav__title">{nextTitle}</div>
    </a>
  ) : <div />}
</nav>

<style>
  .chapter-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid var(--ps-color-rule);
  }
  .chapter-nav__link {
    display: flex; flex-direction: column; gap: 6px;
    padding: 20px 24px;
    background: var(--ps-color-paper);
    border: 1px solid var(--ps-color-rule);
    border-radius: 8px;
    text-decoration: none; color: var(--ps-color-ink);
    transition: border-color 0.15s ease, transform 0.12s ease;
  }
  .chapter-nav__link:hover { border-color: var(--ps-color-ms-blue-500); transform: translateY(-1px); }
  .chapter-nav__link--prev { text-align: left; }
  .chapter-nav__link--next { text-align: right; }
  .chapter-nav__dir {
    font-family: var(--ps-font-mono);
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ps-color-ms-blue-700);
  }
  :root[data-theme="dark"] .chapter-nav__dir { color: var(--ps-color-ms-blue-500); }
  .chapter-nav__title { font-size: 16px; font-weight: 500; line-height: 1.3; text-wrap: balance; }
  @media (max-width: 720px) {
    .chapter-nav { grid-template-columns: 1fr; }
    .chapter-nav__link--next { text-align: left; }
  }
</style>
