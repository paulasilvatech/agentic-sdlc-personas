---
import type { Locale } from '../../lib/i18n';
import { LOCALES } from '../../lib/i18n';

interface Props {
  currentLocale: Locale;
  currentPath: string;
}

const { currentLocale, currentPath } = Astro.props;

const LABELS: Record<Locale, string> = {
  en: 'English',
  pt: 'Português',
  es: 'Español',
};

const SHORT: Record<Locale, string> = {
  en: 'EN',
  pt: 'PT',
  es: 'ES',
};

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function pathForLocale(loc: Locale): string {
  // Remove base
  let pathNoBase = currentPath;
  if (base && pathNoBase.startsWith(base)) pathNoBase = pathNoBase.slice(base.length);
  // Remove trailing slash for processing
  pathNoBase = pathNoBase.replace(/\/$/, '') || '/';
  // Strip existing locale prefix (pt or es)
  const stripped = pathNoBase.replace(/^\/(pt|es)(\/|$)/, '/').replace(/\/$/, '') || '/';
  if (loc === 'en') return `${base}${stripped}/`.replace(/\/\/$/, '/');
  return `${base}/${loc}${stripped === '/' ? '' : stripped}/`;
}
---

<div class="lang-switcher" role="group" aria-label="Language">
  {LOCALES.map(loc => (
    <a
      href={pathForLocale(loc)}
      class:list={['lang-switcher__btn', { 'is-current': loc === currentLocale }]}
      aria-current={loc === currentLocale ? 'page' : undefined}
      title={LABELS[loc]}
      hreflang={loc}
    >
      {SHORT[loc]}
    </a>
  ))}
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    background: var(--ps-color-paper);
    border: 1px solid var(--ps-color-rule);
    border-radius: 6px;
  }
  .lang-switcher__btn {
    padding: 6px 10px;
    background: transparent;
    border-radius: 4px;
    font-family: var(--ps-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ps-color-ink-3);
    text-decoration: none;
    line-height: 1;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .lang-switcher__btn:hover {
    color: var(--ps-color-ink);
    background: var(--ps-color-bg-alt);
  }
  .lang-switcher__btn.is-current {
    background: var(--ps-color-ms-blue-500);
    color: white;
  }
</style>
