---
/**
 * BrandMark, paulasilvatech wordmark.
 * Text-only logo (no Microsoft-style 4-square mark).
 */
interface Props {
  size?: 'sm' | 'md' | 'lg';
  showText?: boolean;
  href?: string;
}

const { size = 'md', showText = true, href = '/' } = Astro.props;
---

<a href={href} class={`brand-mark brand-mark--${size}`} aria-label="Home">
  {showText && (
    <span class="brand-mark__text">
      <slot>paulasilvatech</slot>
    </span>
  )}
</a>

<style>
  .brand-mark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .brand-mark__text {
    font-family: var(--ps-font-mono);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ps-color-ink);
    line-height: 1;
  }
  .brand-mark--sm .brand-mark__text { font-size: 11px; }
  .brand-mark--md .brand-mark__text { font-size: 12px; }
  .brand-mark--lg .brand-mark__text { font-size: 14px; }
  .brand-mark:hover .brand-mark__text {
    color: var(--ps-color-ms-blue-700);
  }
</style>
