---
import type { Locale } from '../../lib/i18n';
import { getStrings } from '../../lib/i18n';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  locale: Locale;
}

const { headings, locale } = Astro.props;
const t = getStrings(locale);

// Somente H2 e H3 na TOC
const items = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{items.length > 0 && (
  <aside class="toc" aria-label={t.nav.onThisPage}>
    <div class="toc__label">{t.nav.onThisPage}</div>
    <nav>
      <ul class="toc__list">
        {items.map(h => (
          <li data-depth={h.depth}>
            <a href={`#${h.slug}`} class="toc__link" data-toc-link={h.slug}>
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a href="#top" class="toc__back-top">{t.nav.backToTop} ↑</a>
  </aside>
)}

<style>
  .toc {
    position: sticky;
    top: 84px;
    align-self: flex-start;
    width: 240px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding: 28px 20px 40px;
    flex-shrink: 0;
    border-left: 1px solid var(--ps-color-rule);
  }
  .toc__label {
    font-family: var(--ps-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ps-color-ink-3);
    margin-bottom: 12px;
  }
  .toc__list {
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    border-left: 1px solid var(--ps-color-rule);
  }
  .toc__list li {
    margin: 0;
  }
  .toc__list li[data-depth="3"] {
    padding-left: 14px;
  }
  .toc__link {
    display: block;
    padding: 5px 14px;
    margin-left: -1px;
    border-left: 1px solid transparent;
    color: var(--ps-color-ink-2);
    text-decoration: none;
    font-size: 13px;
    line-height: 1.45;
    transition: color 0.12s ease, border-color 0.12s ease;
    text-wrap: balance;
  }
  .toc__link:hover {
    color: var(--ps-color-ink);
  }
  .toc__link.is-active {
    color: var(--ps-color-ms-blue-700);
    border-left-color: var(--ps-color-ms-blue-500);
    font-weight: 500;
  }
  :root[data-theme="dark"] .toc__link.is-active {
    color: var(--ps-color-ms-blue-500);
  }
  .toc__back-top {
    display: inline-block;
    font-family: var(--ps-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ps-color-ink-3);
    text-decoration: none;
  }
  .toc__back-top:hover { color: var(--ps-color-ink); }

  @media (max-width: 1280px) {
    .toc { display: none; }
  }
</style>

<script>
  // Active heading observer
  (() => {
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    if (!links.length) return;
    const map = new Map<string, HTMLAnchorElement>();
    links.forEach(l => {
      const slug = l.dataset.tocLink;
      if (slug) map.set(slug, l);
    });

    const headings = Array.from(map.keys())
      .map(slug => document.getElementById(slug))
      .filter((h): h is HTMLElement => h !== null);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          const id = entry.target.id;
          const link = map.get(id);
          if (!link) return;
          if (entry.isIntersecting) {
            links.forEach(l => l.classList.remove('is-active'));
            link.classList.add('is-active');
          }
        });
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );

    headings.forEach(h => observer.observe(h));
  })();
</script>
