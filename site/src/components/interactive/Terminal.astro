---
/**
 * Terminal, simulação de sessão terminal com typing animation.
 * Uso em MDX:
 *   <Terminal lines={[
 *     { kind: 'prompt', text: 'kubectl get agents' },
 *     { kind: 'output', text: 'NAME...' }
 *   ]} />
 */
interface Line {
  kind: 'prompt' | 'output' | 'comment' | 'error' | 'success';
  text: string;
  delay?: number;
}
interface Props {
  title?: string;
  lines: Line[];
  prompt?: string;
  autoplay?: boolean;
}
const { title = 'terminal', lines, prompt = '$', autoplay = true } = Astro.props;

// Unique id for this instance
const id = 'term-' + Math.random().toString(36).slice(2, 9);
const linesJson = JSON.stringify(lines);
---

<figure class="terminal" data-terminal={id} data-autoplay={String(autoplay)}>
  <div class="terminal__chrome">
    <div class="terminal__dots" aria-hidden="true">
      <span style="background:#FF5F57"></span>
      <span style="background:#FEBC2E"></span>
      <span style="background:#28C840"></span>
    </div>
    <div class="terminal__title">{title}</div>
    <button type="button" class="terminal__replay" data-terminal-replay={id} aria-label="Replay">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
        <path d="M9 3a4 4 0 1 0 1 4"/>
        <path d="M9 1v3H6"/>
      </svg>
    </button>
  </div>
  <div class="terminal__body" data-terminal-body={id}>
    <div class="terminal__content" data-terminal-content={id}></div>
  </div>
  <script type="application/json" data-terminal-lines={id} set:html={linesJson}></script>
  <figcaption class="terminal__fallback">
    {lines.map(l => (
      <div class={`terminal__fallback-line terminal__fallback-line--${l.kind}`}>
        {l.kind === 'prompt' && <span class="terminal__fallback-prompt">{prompt}</span>}
        <span>{l.text}</span>
      </div>
    ))}
  </figcaption>
</figure>

<style>
  .terminal {
    margin: 28px 0;
    background: #0f1115;
    border: 1px solid #1e222a;
    border-radius: 8px;
    overflow: hidden;
    font-family: var(--ps-font-mono);
    font-size: 13px;
    line-height: 1.6;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }
  .terminal__chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: #1a1d24;
    border-bottom: 1px solid #252933;
  }
  .terminal__dots {
    display: flex;
    gap: 6px;
  }
  .terminal__dots span {
    width: 11px; height: 11px;
    border-radius: 50%;
  }
  .terminal__title {
    flex: 1;
    text-align: center;
    font-size: 11px;
    color: #868b95;
    font-family: var(--ps-font-mono);
    letter-spacing: 0.06em;
  }
  .terminal__replay {
    background: transparent;
    border: none;
    color: #868b95;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
  }
  .terminal__replay:hover { color: #e1e3e8; background: #252933; }
  .terminal__body {
    padding: 16px 20px 20px;
    min-height: 140px;
    color: #e1e3e8;
    overflow-x: auto;
  }
  .terminal__content { white-space: pre-wrap; }
  .terminal__line { display: block; min-height: 1.6em; }
  .terminal__line--prompt::before {
    content: '$ ';
    color: #7fba00;
    font-weight: 500;
  }
  .terminal__line--comment {
    color: #6b7280;
    font-style: italic;
  }
  .terminal__line--output {
    color: #c7cacf;
  }
  .terminal__line--error {
    color: #f25022;
  }
  .terminal__line--success {
    color: #7fba00;
  }
  .terminal__cursor {
    display: inline-block;
    width: 7px;
    height: 1em;
    vertical-align: -2px;
    background: #7fba00;
    animation: term-blink 1s step-end infinite;
  }
  @keyframes term-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
  .terminal__fallback { display: none; }
  @media (prefers-reduced-motion: reduce) {
    .terminal__cursor { animation: none; }
  }
</style>

<script>
  (() => {
    const scripts = document.querySelectorAll<HTMLScriptElement>('[data-terminal-lines]');
    scripts.forEach(script => {
      const id = script.dataset.terminalLines;
      if (!id) return;
      const content = document.querySelector<HTMLElement>(`[data-terminal-content="${id}"]`);
      const replay = document.querySelector<HTMLElement>(`[data-terminal-replay="${id}"]`);
      const terminal = document.querySelector<HTMLElement>(`[data-terminal="${id}"]`);
      if (!content || !terminal) return;

      let lines: any[] = [];
      try { lines = JSON.parse(script.textContent || '[]'); } catch { return; }

      const reduceMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;

      async function play() {
        content.innerHTML = '';
        for (const line of lines) {
          const el = document.createElement('span');
          el.className = `terminal__line terminal__line--${line.kind}`;
          content.appendChild(el);

          if (reduceMotion || line.kind !== 'prompt') {
            el.textContent = line.text + '\n';
            await sleep(line.delay ?? (line.kind === 'prompt' ? 200 : 30));
          } else {
            // Typing animation for prompts
            for (let i = 0; i < line.text.length; i++) {
              el.textContent = line.text.slice(0, i + 1);
              await sleep(28 + Math.random() * 22);
            }
            el.textContent = line.text + '\n';
            await sleep(260);
          }
        }
        const cursor = document.createElement('span');
        cursor.className = 'terminal__cursor';
        content.appendChild(cursor);
      }

      function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }

      // Intersection observer: play when visible
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting && terminal.dataset.played !== '1') {
            terminal.dataset.played = '1';
            play();
            observer.unobserve(e.target);
          }
        });
      }, { threshold: 0.3 });

      if (terminal.dataset.autoplay !== 'false') {
        observer.observe(terminal);
      }

      replay?.addEventListener('click', () => {
        terminal.dataset.played = '1';
        play();
      });
    });
  })();
</script>
