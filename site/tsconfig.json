{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@layouts/*":    ["src/layouts/*"],
      "@content/*":    ["src/content/*"],
      "@i18n/*":       ["src/i18n/*"],
      "@lib/*":        ["src/lib/*"],
      "@styles/*":     ["src/styles/*"]
    }
  }
}
